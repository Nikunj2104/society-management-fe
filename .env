# In Expo, any environment variables starting with EXPO_PUBLIC_ are automatically bundled into your app when you compile the APK.

# Change this to your Vercel URL once you deploy the backend.
# Do not add a trailing slash. Example: https://my-backend.vercel.app/api
EXPO_PUBLIC_API_URL=http://localhost:5000/api
# EXPO_PUBLIC_API_URL=https://society-management-be-ruddy.vercel.app/api
